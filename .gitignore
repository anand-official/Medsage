# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.js

# testing
/coverage

# production
/build

# misc
.DS_Store

# ============================================================
# 🔐 SECRETS — NEVER COMMIT THESE
# ============================================================
.env
.env.local
.env.production
server/.env
server/.env.local
server/.env.production
# Keep .env.example files (they are safe templates, not secrets)
!.env.example
!server/.env.example
# ============================================================

# Qdrant local storage
qdrant_storage/

# Server crash and crawler logs
server/crash*.log
server/crawler.log
server/crawl_v2_log.txt
server/error_utf8.log

# Runtime data files (not for version control)
server/data/chat_history.json
server/data/benchmark_results.json
server/data/tuning_results.json

npm-debug.log*
yarn-debug.log*
yarn-error.log*
