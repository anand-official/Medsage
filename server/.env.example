# ─────────────────────────────────────────────
# MedSage Backend — Environment Variables
# Copy this file to server/.env and fill in real values
# NEVER commit server/.env to git
# ─────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/medsage?retryWrites=true&w=majority

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=your_strong_random_jwt_secret_here

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# HuggingFace (for embeddings)
HF_API_TOKEN=your_huggingface_api_token_here
HF_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# Google Books API
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here

# Firebase Admin SDK (from Firebase Console → Project Settings → Service Accounts → Generate new private key)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Qdrant Vector DB (use Qdrant Cloud for production: https://cloud.qdrant.io)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_if_using_cloud

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://medsage.ai,https://www.medsage.ai
